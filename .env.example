# Google Places enrichment is optional but recommended when deploying the
# backend proxy. If unset, restaurant search still works without ratings.
GOOGLE_MAPS_API_KEY=your_google_maps_server_key

# Optional: customize the server-side User-Agent sent to Nominatim.
NOMINATIM_USER_AGENT=RandomPinCuisine/1.0

# Optional: Redis connection URL for durable caching across cold starts.
# If unset, the app falls back to an in-memory cache (same as before).
# Example: redis://default:password@your-redis-host:6379
REDIS_URL=
