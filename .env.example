# Mapbox GL JS (required for globe map)
# Get a free token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token

# Anthropic Claude API (for cuisine classification)
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key

# Optional: Claude model to use (defaults to claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Yelp Fusion API (for restaurant search)
# Get a key at https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your_yelp_api_key

# Optional: Site URL for OG metadata (defaults to random-pin.michaelpyon.com)
# NEXT_PUBLIC_SITE_URL=https://random-pin.michaelpyon.com
